# Copy this file to .env and fill in your own values.
# Never commit .env — it contains secrets.

# ─── Confluence API ─────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://orchardhome.atlassian.net/wiki
CONFLUENCE_EMAIL=your.email@orchard.com.au
# Generate at https://id.atlassian.com/manage-profile/security/api-tokens
# (use "Create API token", NOT "Create API token with scopes")
CONFLUENCE_API_TOKEN=your-atlassian-api-token

# Optional: credentials used ONLY by scripts/fetchFeatures.js for
# downloading feature file attachments from a personal space.
# Leave blank to fall back to the default CONFLUENCE_EMAIL / TOKEN above.
#CONFLUENCE_FETCH_EMAIL=
#CONFLUENCE_FETCH_TOKEN=

# ─── Confluence Page IDs ────────────────────────────────────────
CONFLUENCE_TEST_DATA_PAGE_ID=1776353299
CONFLUENCE_FEATURE_FILE_PAGE_ID=1729724417

# ─── Test Configuration ─────────────────────────────────────────
TARGET_ENVIRONMENT=Stage
HEADLESS=true
